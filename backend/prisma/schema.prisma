generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth (Phase 2) — User/Session/Account/Verification are better-auth's core
// tables (shapes fixed by better-auth; extra columns like `role` are declared
// as additionalFields in src/lib/auth.ts)
// ---------------------------------------------------------------------------

enum Role {
  admin
  editor // invited; can write wiki content
  viewer // default; read needs no login
}

model User {
  id            String  @id
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?
  role          Role    @default(viewer)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  accounts Account[]

  macroSets           MacroSet[]
  definitionsCreated  Definition[]
  formulationsCreated Formulation[]
  revisionsAuthored   Revision[]
  macroNamesCreated   MacroName[]
  invitationsSent     Invitation[]  @relation("InvitationsSent")
  invitationAccepted  Invitation?   @relation("InvitationAccepted")
}

model Session {
  id        String   @id
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
}

// admin invites an email; on first OAuth sign-in with that email the account
// gets the invited role (default editor)
model Invitation {
  id    Int    @id @default(autoincrement())
  email String @unique // stored lowercased
  role  Role   @default(editor)

  createdAt DateTime @default(now())

  invitedBy   User?   @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedById String?

  acceptedAt   DateTime?
  acceptedBy   User?     @relation("InvitationAccepted", fields: [acceptedById], references: [id], onDelete: SetNull)
  acceptedById String?   @unique
}

// high-level concept of a definition (e.g. PRF); holds no LaTeX itself
model Definition {
  id    Int    @id @default(autoincrement())
  slug  String @unique // stable URL slug (e.g. "prf") — permanent once anything is published
  title String @unique // display title (e.g. "Pseudorandom Function")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // nullable: pre-auth content has no recorded author
  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?

  formulations Formulation[]
  categories   Category[]
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique

  definitions Definition[]
}

// one way of formalizing a definition (e.g. game-based vs indistinguishability-based)
model Formulation {
  id        Int     @id @default(autoincrement())
  slug      String
  isDefault Boolean @default(false)
  order     Int     @default(0)

  // citation metadata: the paper this formulation originates from
  citePaper   String?
  citeAuthors String?
  citeVenue   String?
  citeYear    Int?
  citeDoi     String?
  citeEprint  String?
  citeUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?

  definition   Definition @relation(fields: [definitionId], references: [id])
  definitionId Int

  // used when a request doesn't specify ?macros=
  defaultMacroSet   MacroSet? @relation(fields: [defaultMacroSetId], references: [id])
  defaultMacroSetId Int?

  revisions Revision[]

  @@unique([definitionId, slug])
  @@unique([definitionId, order])
}

enum RevisionStatus {
  draft
  published
}

// an edit within a formulation; published revisions are immutable (enforced at the API layer)
model Revision {
  id           Int            @id @default(autoincrement())
  status       RevisionStatus @default(draft)
  number       Int? // assigned at publish time — the "r2" in /def/prf/game-based@r2
  bodyLatex    String // pure LaTeX fragment, compilable by real LaTeX
  commentaryMd String         @default("") // markdown commentary: intuition, remarks, cross-links

  // definition-scoped macro layers (PLAN.md "Layered macros"), frozen at
  // publish with the body. `macros` = shared symbols (registered names, the
  // definition's default expansions; notation sets may override). `localMacros`
  // = definition-private macros, merged last at render so notation sets can
  // never touch them. Classification is stored here, NOT derived from the
  // registry at render time — published renders must never drift.
  macros      Json @default("{}")
  localMacros Json @default("{}")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  author   User?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorId String?

  formulation   Formulation @relation(fields: [formulationId], references: [id])
  formulationId Int

  @@unique([formulationId, number])
}

// site-wide registry of canonical macro names ("\enc" = encryption algorithm,
// "\encode" = code encoder, ...). Notation sets may only define registered
// names (validated at write time). Never consulted at render time.
model MacroName {
  id          Int    @id @default(autoincrement())
  name        String @unique // control sequence incl. backslash, e.g. "\\enc"
  description String // one-line meaning shown wherever the name appears

  createdAt DateTime @default(now())

  createdBy   User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdById String?
}

enum MacroSetVisibility {
  public // listed in the site directory
  unlisted // link-only
  anonymous // link-only, zero public attribution (double-blind); never serialize timestamps
}

model MacroSet {
  id         Int                @id @default(autoincrement())
  uuid       String             @unique @default(uuid()) // unguessable URL handle
  name       String
  macros     Json
  visibility MacroSetVisibility @default(public)

  // nullable: pre-auth sets have no owner (manageable by admins only).
  // NEVER serialized publicly for anonymous sets — see lib/serialize.ts.
  owner   User?   @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  ownerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  formulations Formulation[]
  snapshots    MacroSetSnapshot[]
}

// immutable content snapshot for permalink pinning (?macros=<uuid>@<hash>)
model MacroSetSnapshot {
  id     Int    @id @default(autoincrement())
  hash   String // sha256 hex of the canonical JSON of `macros`
  macros Json

  createdAt DateTime @default(now())

  macroSet   MacroSet @relation(fields: [macroSetId], references: [id], onDelete: Cascade)
  macroSetId Int

  @@unique([macroSetId, hash])
}

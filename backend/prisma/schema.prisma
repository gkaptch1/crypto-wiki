generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// high-level concept of a definition (e.g. PRF); holds no LaTeX itself
model Definition {
  id    Int    @id @default(autoincrement())
  slug  String @unique // stable URL slug (e.g. "prf") — permanent once anything is published
  title String @unique // display title (e.g. "Pseudorandom Function")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  formulations Formulation[]
  categories   Category[]
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique

  definitions Definition[]
}

// one way of formalizing a definition (e.g. game-based vs indistinguishability-based)
model Formulation {
  id        Int     @id @default(autoincrement())
  slug      String
  isDefault Boolean @default(false)
  order     Int     @default(0)

  // citation metadata: the paper this formulation originates from
  citePaper   String?
  citeAuthors String?
  citeVenue   String?
  citeYear    Int?
  citeDoi     String?
  citeEprint  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  definition   Definition @relation(fields: [definitionId], references: [id])
  definitionId Int

  // used when a request doesn't specify ?macros=
  defaultMacroSet   MacroSet? @relation(fields: [defaultMacroSetId], references: [id])
  defaultMacroSetId Int?

  revisions Revision[]

  @@unique([definitionId, slug])
  @@unique([definitionId, order])
}

enum RevisionStatus {
  draft
  published
}

// an edit within a formulation; published revisions are immutable (enforced at the API layer)
model Revision {
  id           Int            @id @default(autoincrement())
  status       RevisionStatus @default(draft)
  number       Int? // assigned at publish time — the "r2" in /def/prf/game-based@r2
  bodyLatex    String // pure LaTeX fragment, compilable by real LaTeX
  commentaryMd String         @default("") // markdown commentary: intuition, remarks, cross-links

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  publishedAt DateTime?

  formulation   Formulation @relation(fields: [formulationId], references: [id])
  formulationId Int

  @@unique([formulationId, number])
}

enum MacroSetVisibility {
  public // listed in the site directory
  unlisted // link-only
  anonymous // link-only, zero public attribution (double-blind); never serialize timestamps
}

model MacroSet {
  id         Int                @id @default(autoincrement())
  uuid       String             @unique @default(uuid()) // unguessable URL handle
  name       String
  macros     Json
  visibility MacroSetVisibility @default(public)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  formulations Formulation[]
  snapshots    MacroSetSnapshot[]
}

// immutable content snapshot for permalink pinning (?macros=<uuid>@<hash>)
model MacroSetSnapshot {
  id     Int    @id @default(autoincrement())
  hash   String // sha256 hex of the canonical JSON of `macros`
  macros Json

  createdAt DateTime @default(now())

  macroSet   MacroSet @relation(fields: [macroSetId], references: [id], onDelete: Cascade)
  macroSetId Int

  @@unique([macroSetId, hash])
}
